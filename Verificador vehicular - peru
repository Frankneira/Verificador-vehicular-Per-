        if not datos:
            for nombre, variantes in campos_mapa.items():
                for variante in variantes:
                    try:
                        el = page.locator(f"*:has-text('{variante}')").last
                        if await el.count() > 0:
                            texto = await el.inner_text()
                            lineas = [l.strip() for l in texto.split("\n") if l.strip()]
                            if len(lineas) >= 2:
